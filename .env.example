# ─── Supabase ────────────────────────────────────────────────────────────────
# Public vars (safe to expose to the browser bundle)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only — never prefix with NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Site Auth ───────────────────────────────────────────────────────────────
# Password that gates access to the entire app (all routes except /api/login
# and /api/worker/* are protected by src/middleware.ts)
SITE_PASSWORD=your-site-password

# Secret for admin-only API endpoints (x-admin-secret header)
ADMIN_SECRET=your-admin-secret

# ─── Worker / Cron ───────────────────────────────────────────────────────────
# Shared secret for the /api/worker/generate endpoint.
# Supply via x-cron-secret header or Authorization: Bearer <secret>.
CRON_SECRET=your-cron-secret

# ─── AI / Video Generation ───────────────────────────────────────────────────
# Google Gemini / Veo API key (server-only)
GEMINI_API_KEY=your-gemini-key
GOOGLE_AI_API_KEY=your-google-ai-key

# LTX video generation API key (server-only)
LTX_API_KEY=your-ltx-key

# ─── Bug / Feature Tracker (BFT) ─────────────────────────────────────────────
BFT_API_KEY=your-bft-api-key
BFT_BASE_URL=https://your-bft-instance.example.com
BFT_PROJECT_ID=your-bft-project-id

# ─── Generation Tuning (optional) ────────────────────────────────────────────
# All of these have sensible defaults; only set to override.
# GEMINI_IMAGE_MODEL=gemini-3.1-flash-image-preview
# GEMINI_IMAGE_RESOLUTION_DEFAULT=4K
# GENERATION_BATCH_SIZE=
# GENERATION_PARALLELISM=
# GENERATION_TIME_BUDGET_MS=
# GENERATION_JOB_BATCH_SIZE=
# GENERATION_JOB_CONCURRENCY=
# IMAGE_JOB_CONCURRENCY=
# VIDEO_JOB_CONCURRENCY=
# GENERATION_VARIATION_RETRIES=
# GENERATION_RETRY_BASE_MS=
# GENERATION_VARIATION_TIMEOUT_MS=
# GENERATION_STATUS_REFRESH_INTERVAL_MS=
# GENERATION_RUNNING_STALE_MS=
# INLINE_GENERATION=false

# ─── Veo Video Tuning (optional) ─────────────────────────────────────────────
# VEO_MODEL=
# VEO_API_BASE_URL=
# VEO_ASPECT_RATIO=
# VEO_RESOLUTION=
# VEO_DURATION_SECONDS=
# VEO_SUPPORTS_AUDIO=false
# VEO_DEBUG=false
# VEO_REQUEST_TIMEOUT_MS=
# VEO_POLL_INTERVAL_MS=
# VEO_POLL_TIMEOUT_MS=
# VEO_DOWNLOAD_TIMEOUT_MS=
# VIDEO_FRAME_FETCH_TIMEOUT_MS=

# ─── LTX Video Tuning (optional) ─────────────────────────────────────────────
# LTX_API_BASE_URL=
# LTX_MODEL=
# LTX_RESOLUTION=
# LTX_DURATION=
# LTX_REQUEST_TIMEOUT_MS=

# ─── Cost Tracking (optional) ────────────────────────────────────────────────
# IMAGE_COST_2K=
# IMAGE_COST_4K=
# CLAUDE_COST_PER_1K=
